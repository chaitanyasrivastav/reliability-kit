{
  "name": "@reliability-tools/fastify",
  "version": "0.4.1",
  "description": "Idempotency engine for Fastify with pluggable storage and atomic locking",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "homepage": "https://github.com/chaitanyasrivastav/reliability-kit/blob/main/packages/fastify/README.md",
  "keywords": [
    "idempotency",
    "fastify",
    "fastify plugin",
    "nodejs",
    "api reliability",
    "duplicate request",
    "retry safe",
    "idempotency key",
    "distributed systems",
    "concurrency control",
    "redis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chaitanyasrivastav/reliability-kit",
    "directory": "packages/fastify"
  },
  "bugs": {
    "url": "https://github.com/chaitanyasrivastav/reliability-kit/issues"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest tests/unit --forceExit --detectOpenHandles",
    "test:integration": "jest tests/integration --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "npm run typecheck && tsup",
    "build:ci": "npm run format:check && npm run lint && npm run typecheck && tsup"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 95,
        "lines": 95,
        "statements": 95
      }
    },
    "coveragePathIgnorePatterns": [
      "src/index.ts",
      "src/middleware/reliability.ts",
      "src/types/framework.ts"
    ]
  },
  "license": "MIT",
  "peerDependencies": {
    "fastify": "^4 || ^5"
  },
  "dependencies": {
    "@reliability-tools/core": "^0.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "fastify": "^5.8.2",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
